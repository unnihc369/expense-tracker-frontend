# Copy to .env.local — Next.js dev server: http://localhost:3000
# Local dev frontend: http://localhost:3000
# Production frontend: https://finvoicepro.vercel.app/login

# Express API. Must include /api.
# Local dev: http://localhost:8080/api
# Production: https://finvoicepro-back.vercel.app/api
API_BASE_URL=http://localhost:8080/api

# Only if client code needs the API URL in the browser bundle (optional for this app).
NEXT_PUBLIC_API_URL=http://localhost:8080/api
